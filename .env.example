# Postgres connection string. Get a free one from https://neon.tech in 60 seconds.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Password for the admin panel at /poll-admin. Set this to something strong.
ADMIN_SECRET=change-me-to-something-secret

# Optional. Used only to build absolute URLs for QR codes.
# If not set, the API derives the URL from the request headers.
# PUBLIC_BASE_URL=https://yourdomain.com
